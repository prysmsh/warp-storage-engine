[Unit]
Description=Warp Storage Engine - High-performance S3-compatible proxy
Documentation=https://github.com/{{ .Env.GITHUB_REPOSITORY }}
After=network.target
Wants=network.target

[Service]
Type=simple
User=warp-storage-engine
Group=warp-storage-engine
ExecStart=/usr/bin/warp-storage-engine -config /etc/warp-storage-engine/config.yaml
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal
SyslogIdentifier=warp-storage-engine
KillMode=mixed
KillSignal=SIGTERM

# Security settings
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/warp-storage-engine
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true

[Install]
WantedBy=multi-user.target
